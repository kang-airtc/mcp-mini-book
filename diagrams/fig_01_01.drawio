      <mxGeometry x="400" y="60" width="240" height="80" as="geometry" />
    </mxCell>
    <mxCell id="server" value="MCP Server" style="swimlane;startSize=30;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#333333;fontSize=13;fontStyle=1;" vertex="1" parent="1">
