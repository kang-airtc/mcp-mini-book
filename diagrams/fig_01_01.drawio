    <mxCell id="e1" value="输入" style="exitX=0.5;exitY=1;entryX=0.5;entryY=0;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#666666;fontSize=11;" edge="1" parent="1" source="user" target="host">
